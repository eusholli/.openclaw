# ============================================
# OpenClaw Config - Git Ignore
# ============================================
# SECURITY FIRST: Block all sensitive files
# ============================================

# --- CREDENTIALS & SECRETS (CRITICAL) ---
# API keys, auth tokens, private keys
identity/
credentials/
devices/
exec-approvals.json
agents/*/agent/auth-profiles.json
agents/*/agent/auth.json

# --- RUNTIME & EPHEMERAL DATA ---
# Instance-specific state, not shareable
/memory/
logs/
completions/
cron/
subagents/
canvas/
update-check.json

# --- SESSION DATA ---
# Agent conversation history (instance-specific)
agents/*/sessions/

# --- BACKUP FILES ---
*.bak
*.bak.*

# --- WORKSPACE RUNTIME (keep the .md files, ignore state) ---
workspace/.openclaw/
workspace/.pi/
workspace/device.identity.json/
workspace-tavily/.openclaw/
workspace-tavily/.pi/
workspace-tavily/device.identity.json/

# --- WORKSPACE MEMORY / RESEARCH ARTIFACTS ---
# AI-generated runtime data: daily notes, company/person profiles, event summaries
# These are operational, not shareable config — keep only workspace/*.md behavior files tracked
workspace/memory/
workspace-tavily/memory/
workspace-long-context/memory/

# Research artifacts placed in workspace root (add as needed)
workspace/AT&T_Sales_Intelligence_2026.md
workspace/Krishna_Rao.md

# --- DEVICE IDENTITY ---
# Each install has its own device identity
device.identity.json/

# --- GENERAL ---
node_modules/
.cache/
*.sqlite
*.sqlite-journal
*.sqlite-wal
